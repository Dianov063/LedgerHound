# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (email delivery)
RESEND_API_KEY=re_...

# Alchemy (already used in trace-graph)
# ALCHEMY_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Multi-chain
TRONGRID_API_KEY=your_trongrid_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
ETHERSCAN_API_KEY=your_etherscan_v2_api_key
HELIUS_API_KEY=your_helius_api_key

# AWS S3 (PDF report storage)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-bucket-name

# Admin
ADMIN_PASSWORD=your_admin_password
CRON_SECRET=use_a_random_value_with_at_least_16_characters

# Cloudflare Turnstile (payment report anti-bot check)
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
TURNSTILE_ALLOWED_HOSTNAMES=ledgerhound.vip,www.ledgerhound.vip

# Shared rate limiting
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
